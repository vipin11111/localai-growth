rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper to check if user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }

    // Helper to verify item belongs to user
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // Allow authenticated users to manage their business profile
    match /businesses/{businessId} {
      allow read, write: if isAuthenticated() && (request.auth.uid == businessId || request.auth.uid == resource.data.userId);
    }

    // Leads can be read/written by the business owner (matched by userId)
    match /leads/{leadId} {
      allow read, write: if isAuthenticated();
    }

    // Generated marketing, content and chats
    match /contents/{contentId} {
      allow read, write: if isAuthenticated();
    }

    match /marketing/{marketingId} {
      allow read, write: if isAuthenticated();
    }

    match /chats/{chatId} {
      allow read, write: if isAuthenticated();
    }
  }
}
